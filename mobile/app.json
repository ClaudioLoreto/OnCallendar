{
  "expo": {
    "name": "OnCallendar",
    "slug": "oncallendar",
    "version": "0.1.0",
    "scheme": "oncallendar",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F8F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "local.oncallendar",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "OnCallendar usa la galleria solo per impostare la tua foto profilo.",
        "NSCameraUsageDescription": "OnCallendar non usa la fotocamera. Questa autorizzazione non viene richiesta in fase di scelta dell'avatar."
      }
    },
    "android": {
      "package": "local.oncallendar",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F8F0"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "OnCallendar usa la galleria solo per impostare la tua foto profilo.",
          "cameraPermission": "OnCallendar non usa la fotocamera per la foto profilo."
        }
      ],
      "expo-secure-store"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiBaseUrl": null,
      "eas": {
        "projectId": ""
      }
    }
  }
}
