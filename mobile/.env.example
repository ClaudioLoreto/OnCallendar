# Override per sviluppo locale: punta al backend .NET in esecuzione sul tuo PC.
# Lascia EXPO_PUBLIC_API_BASE_URL VUOTO per attivare l'auto-detect via LAN
# (apiClient.ts userà l'IP del Metro bundler + porta 5000).
#
# Se vuoi forzarlo a un IP specifico (utile se Expo Go non lo rileva), scommentati
# la riga sotto sostituendo l'IP con quello della tua macchina sulla rete Wi-Fi.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:5000

# Per puntare alla produzione Railway (test "come in prod"):
# EXPO_PUBLIC_API_BASE_URL=https://api-production-e42a.up.railway.app
